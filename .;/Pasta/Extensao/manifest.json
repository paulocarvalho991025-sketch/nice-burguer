{
  "manifest_version": 3,
  "name": "Gate x MEXC Arbitragem",
  "version": "1.0",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": [
    "https://www.gate.com/*",
    "https://www.mexc.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.gate.com/*", "https://www.mexc.com/*"],
      "js": ["AppState.js", "MessageHandler.js", "Toast.js", "RateLimit.js", "utils.js", "content.js", "mexc.js", "trading.js","page.js"],
      "css": ["style.css"]
    }
  ]
}
